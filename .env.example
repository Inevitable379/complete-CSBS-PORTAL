# CSBS Portal — environment template.
# Copy to `.env` and fill in real values. NEVER commit the real .env.

# Strong random string used to sign session cookies.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Google OAuth client ID (public — used for Sign in with Google).
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Comma-separated emails (must also be on the whitelist) that get admin access.
ADMIN_EMAILS=you@jainuniversity.ac.in

# Runtime
PORT=5001
DEBUG=False
# Only 'true' for local development — enables the skip-login dev button.
ALLOW_DEV_BYPASS=false
SESSION_DAYS=7

# Max upload size in megabytes.
MAX_UPLOAD_MB=25

# Allowed browser origins (same-origin deploys can leave this as the host URL).
CORS_ORIGINS=http://localhost:5001,http://127.0.0.1:5001
